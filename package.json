{
	"name": "tavern",
	"version": "1.0.2",
	"description": "A local-first Obsidian plugin for iterative Tavern workflows.",
	"keywords": [
		"obsidian",
		"obsidian-plugin"
	],
	"license": "0-BSD",
	"type": "module",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"check": "pnpm run build && pnpm run test:ci && pnpm run lint:ci && pnpm run knip:ci && pnpm run test:mutation",
		"check:ci": "pnpm run build && pnpm run test:ci && pnpm run lint:ci && pnpm run knip:ci",
		"version": "node version-bump.mjs && git add package.json manifest.json versions.json",
		"release": "semantic-release",
		"release:dry-run": "semantic-release --dry-run --no-ci",
		"release:version": "node scripts/set-version.mjs",
		"lint": "oxlint .",
		"prepare": "husky",
		"lint:fix": "oxlint . --fix",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"fix:staged": "lint-staged --concurrent false",
		"lint:staged": "pnpm run fix:staged",
		"lint:type-aware": "oxlint . --type-aware --type-check",
		"lint:type-aware:fix": "oxlint . --type-aware --type-check --fix",
		"fix": "pnpm run lint:type-aware:fix && pnpm run format",
		"lint:ci": "pnpm run lint:type-aware && pnpm run format:check",
		"typecheck": "tsc -noEmit -skipLibCheck",
		"test": "vitest run --config vitest.config.mts",
		"test:watch": "vitest --config vitest.config.mts",
		"test:coverage": "vitest run --coverage --config vitest.config.mts",
		"test:ci": "vitest run --coverage --config vitest.config.mts",
		"test:mutation": "stryker run",
		"test:mutation:incremental": "stryker run --incremental",
		"knip": "knip --cache --strict",
		"knip:watch": "knip --watch --strict",
		"knip:ci": "knip --cache --strict"
	},
	"dependencies": {
		"effect": "^3.21.2",
		"obsidian": "1.8.7"
	},
	"devDependencies": {
		"@j178/prek": "^0.3.8",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.8",
		"@semantic-release/release-notes-generator": "^14.1.1",
		"@stryker-mutator/core": "~9.6.0",
		"@stryker-mutator/typescript-checker": "~9.6.0",
		"@stryker-mutator/vitest-runner": "~9.6.0",
		"@types/node": "^22.0.0",
		"@vitest/coverage-v8": "~4.1.0",
		"esbuild": "^0.27.0",
		"husky": "^9.1.7",
		"knip": "^6.3.0",
		"lint-staged": "^16.4.0",
		"oxfmt": "^0.43.0",
		"oxlint": "^1.58.0",
		"oxlint-tsgolint": "^0.22.1",
		"semantic-release": "^25.0.3",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"vitest": "~4.1.0"
	},
	"lint-staged": {
		"*.{js,mjs,cjs,jsx,ts,mts,cts,tsx}": [
			"oxlint --type-aware --type-check --fix",
			"oxfmt"
		],
		"*.{json,md,yml,yaml,toml,css,scss,html}": [
			"oxfmt"
		]
	},
	"packageManager": "pnpm@10.12.4"
}
